# Per-stack identity + deploy config for the dev stack. Runs in the default aws-cli container
# (github provider; jq auto-installs). Parsed, never sourced.
# TEMPLATE + PARAMETERS are repo-root-relative, so all envs share ONE template (no copies).
SECRETS_PROVIDER=github
AWS_ROLE_ARN=arn:aws:iam::377521353143:role/iac-github-oidc-test
AWS_REGION=us-east-1
STACK_NAME=iac-github-cfn-demo-dev
TEMPLATE=templates/demo.yaml
PARAMETERS=stacks/dev/parameters.json
TAGS=Key=managed_by,Value=iac-github Key=env,Value=dev
