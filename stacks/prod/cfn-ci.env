# Per-stack identity + deploy config for the prod stack. Runs entirely in the default
# aws-cli container (github provider; jq auto-installs). The file is parsed, never sourced.
SECRETS_PROVIDER=github
AWS_ROLE_ARN=arn:aws:iam::377521353143:role/iac-github-oidc-test
AWS_REGION=us-east-1
STACK_NAME=iac-github-cfn-demo-prod
TEMPLATE=template.yaml
PARAMETERS=parameters.json
TAGS=Key=managed_by,Value=iac-github Key=env,Value=prod
